# Clerk Authentication (REQUIRED - get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# Server
PORT=4200
HOST=0.0.0.0
CLIENT_ORIGIN=https://app.digitalwavecrm.com

# MongoDB (REQUIRED for persistence)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/digital-wave-crm

# OpenAI (optional - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# WebSocket
VITE_SERVER_URL=https://api.digitalwavecrm.com

# LemonSqueezy (optional - for billing)
VITE_LEMONSQUEEZY_PRO_CHECKOUT_URL=https://app.lemonsqueezy.com/checkout/buy/YOUR_PRO_VARIANT
VITE_LEMONSQUEEZY_ORG_CHECKOUT_URL=https://app.lemonsqueezy.com/checkout/buy/YOUR_ORG_VARIANT
