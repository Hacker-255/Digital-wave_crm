# Frontend Environment Variables (Vite)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# LemonSqueezy Payment Links (Optional)
VITE_LEMONSQUEEZY_PRO_CHECKOUT_URL=https://app.lemonsqueezy.com/checkout/buy/your_pro_variant_id
VITE_LEMONSQUEEZY_ORG_CHECKOUT_URL=https://app.lemonsqueezy.com/checkout/buy/your_org_variant_id

# Backend Server Configuration
PORT=4200
HOST=127.0.0.1
CLIENT_ORIGIN=http://127.0.0.1:5173

# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/digital-wave-crm

# OpenAI API Configuration (Optional - AI features will gracefully degrade without this)
OPENAI_API_KEY=sk_your_openai_api_key

# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in your actual API keys and configuration values
# 3. For local development with MongoDB:
#    - Ensure MongoDB is running on localhost:27017
#    - Or set MONGODB_URI to your Atlas connection string
# 4. For Clerk authentication:
#    - Get your publishable key from dashboard.clerk.com
# 5. For OpenAI features:
#    - Get your API key from platform.openai.com
#    - Leave empty if you want to use fallback responses
